{
  "name": "cloud-run-env-manager",
  "version": "0.2.2",
  "description": "Web dashboard for managing Google Cloud Run env vars across projects, environments, and services. Cloudflare Worker + Hono + React. OAuth and gcloud CLI auth.",
  "license": "MIT",
  "author": "kosiakmd",
  "homepage": "https://github.com/kosiakMD/cloud-run-env-manager#readme",
  "bugs": {
    "url": "https://github.com/kosiakMD/cloud-run-env-manager/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kosiakMD/cloud-run-env-manager.git"
  },
  "type": "module",
  "keywords": [
    "cloud-run",
    "gcp",
    "google-cloud",
    "env-vars",
    "environment-variables",
    "dashboard",
    "cloudflare-workers",
    "oauth",
    "react",
    "hono"
  ],
  "files": [
    "src",
    "index.html",
    "tsconfig.json",
    "vite.config.ts",
    "postcss.config.js",
    "tailwind.config.js",
    ".env.example",
    ".cloudflare"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "start": "tsx src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:worker": "cd .cloudflare/worker && npx wrangler deploy"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@tanstack/react-query": "^5.59.0",
    "dotenv": "^17.4.2",
    "execa": "^9.5.0",
    "hono": "^4.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sonner": "^1.7.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260416.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.83.0"
  }
}
