# Auth mode: "local" (gcloud CLI) or "oauth" (Google OAuth via user login)
AUTH_MODE=local

# ----- OAUTH MODE ONLY -----
# Google OAuth 2.0 client — Web application type.
# Created in: https://console.cloud.google.com/apis/credentials?project=fairs-dev-414403
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where Google redirects after consent. Must match the OAuth client's
# Authorized redirect URI exactly.
#   local:  http://localhost:5174/api/auth/callback
#   prod:   https://env-manager.dev-fairs.com/api/auth/callback
OAUTH_REDIRECT_URI=http://localhost:5174/api/auth/callback

# Random 64-hex-char secret for encrypting the session cookie.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Origin for post-login redirects (no trailing slash).
PUBLIC_ORIGIN=http://localhost:5174
